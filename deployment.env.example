# =============================================================================
# Path-B External ICAP + Suricata IPS v5.12 — deployment configuration template
# =============================================================================
# Copy this file to deployment.env or generate it with:
#   bash scripts/init-config.sh --proxy-ip <PROXY_VM_IP> --icap-ip <ICAP_VM_IP> \
#     --gateway-ip <GATEWAY_IP> --client-ip <TEST_CLIENT_IP>
#
# This file is intentionally generic. Adjust it to your own lab network before
# installation. Path-B v5.12 is a non-production lab preview.
# =============================================================================

PATHB_ENV_VERSION=5.12

# --- Lab network -------------------------------------------------------------
PATHB_GATEWAY_IP=10.10.10.1
PATHB_DNS_SERVERS="10.10.10.1"
PATHB_NET_CIDR=10.10.10.0/24
PATHB_NET_PREFIX=24

PATHB_PROXY_IP=10.10.10.20
PATHB_SURICATA_IP=10.10.10.30
PATHB_TEST_CLIENT_IP=10.10.10.40

PATHB_INTERFACE=auto
APPLY_NETPLAN=0

# --- ICAP/Suricata VM --------------------------------------------------------
ICAP_BIND=auto
ICAP_PORT=1345
HEALTH_BIND=auto
HEALTH_PORT=2345
ICAP_WORKERS=32
ALLOWED_CLIENTS=auto
ALLOWED_CIDR=auto
FAIL_CLOSED=0

WAIT_TIMEOUT_MS=900
REQMOD_WAIT_TIMEOUT_MS=500
RESPMOD_WAIT_TIMEOUT_MS=400
ALERT_POST_DRAIN_GRACE_MS=60
SURICATA_QUEUE_POLL_MS=10
SURICATA_PIPELINE_CONCURRENCY=6
SURICATA_SUBMIT_RETRIES=3
SURICATA_SUBMIT_RETRY_SLEEP_MS=40
MAX_REQUEST_BYTES=33554432
ICAP_READ_TIMEOUT_S=0.8
PCAP_TCP_MSS=1400
PCAP_RETENTION_SECONDS=300

ICAP_PREVIEW_ENABLE=on
ICAP_PREVIEW_SIZE=32768

RESPMOD_ENABLED=1
RESPMOD_PREVIEW_SCAN=1
RESPMOD_MAX_SCAN_BYTES=262144
RESPMOD_SKIP_COMPRESSED=1
RESPMOD_SCAN_ALL_CONTENT_TYPES=0
RESPMOD_SCAN_SMALL_BODIES_BYTES=131072
RESPMOD_FORCE_SCAN_MARKERS=EICAR-STANDARD-ANTIVIRUS-TEST-FILE,PROXYLAB-ICAP-RESPONSE-TRIGGER

BLOCK_SID_RANGES=9100500-9100999
BLOCK_ON_ANY_ALERT=0
LOG_CLIENT_ABORTS=0
LOG_INCOMPLETE_READS=0
LOG_MONITOR_ALERTS=0
REQMOD_STATIC_BYPASS_ENABLED=1
REQMOD_STATIC_BYPASS_EXTENSIONS=css,js,mjs,map,png,jpg,jpeg,gif,webp,svg,ico,avif,bmp,woff,woff2,ttf,otf,eot,mp4,webm,mp3,m4a,m4v,ogg,wav,wasm,json
REQMOD_STATIC_BYPASS_LOG_SAMPLE_RATE=0
LATENCY_SAMPLE_EVERY=200
SLOW_REQUEST_LOG_MS=350

# --- Proxy VM / Squid --------------------------------------------------------
ENABLE_OUTBOUND=1
OUTBOUND_HTTP_PORT=3128
OUTBOUND_HTTPS_INTERCEPT_PORT=3129
LOCAL_NETS=auto
ICAP_SURICATA_HOST=auto
ICAP_SURICATA_PORT=1345
ICAP_SURICATA_BYPASS=off
ICAP_SURICATA_MAX_CONN=32
ICAP_PERSISTENT_CONNECTIONS=off

ENABLE_CLAMAV_ICAP=0
CLAMAV_BYPASS=on
LOCAL_CLAMAV_SERVICE_NAME=pathb_avscan

# --- Squid CA export ---------------------------------------------------------
CA_SUBJECT="/CN=Proxylab Path-B Inspection CA/O=Proxylab/C=DE"
CA_VALID_DAYS=3650
EXPORT_PRIVATE_CA_KEY=0

# --- Optional inbound reverse-proxy inspection -------------------------------
ENABLE_INBOUND=0
INBOUND_BIND_IP=auto
INBOUND_HTTPS_PORT=443
INBOUND_DOMAIN=app-test.local
INBOUND_CERT=/etc/squid/inbound/app.fullchain.pem
INBOUND_KEY=/etc/squid/inbound/app.privkey.pem
INBOUND_ORIGIN_HOST=10.10.20.50
INBOUND_ORIGIN_PORT=443
INBOUND_ORIGIN_TLS=1
INBOUND_ORIGIN_VERIFY=0
