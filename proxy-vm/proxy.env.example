# =============================================================================
# Path-B v5.12 — Proxy-VM configuration
# Kann direkt aus deployment.env geladen are.
# =============================================================================

PATHB_GATEWAY_IP=10.10.10.1
PATHB_DNS_SERVERS="10.10.10.1"
PATHB_NET_CIDR=10.10.10.0/24
PATHB_NET_PREFIX=24
PATHB_PROXY_IP=10.10.10.20
PATHB_SURICATA_IP=10.10.10.30
PATHB_TEST_CLIENT_IP=10.10.10.40
PATHB_INTERFACE=auto

DEFAULT_GW=auto
PROXY_IF=auto
CLEAR_IF=auto
MGMT_IF=auto
PROXY_IP=auto
CLEAR_IP=auto
MGMT_IP=auto
APPLY_NETPLAN=0

CA_SUBJECT="/CN=Proxylab Path-B Inspection CA/O=Proxylab/C=DE"
CA_VALID_DAYS=3650
SSL_BYPASS_REGEX=/etc/squid/ssl-bypass.regex
EXPORT_PRIVATE_CA_KEY=0

ENABLE_OUTBOUND=1
OUTBOUND_HTTP_PORT=3128
OUTBOUND_HTTPS_INTERCEPT_PORT=3129
LOCAL_NETS=auto

ICAP_SURICATA_HOST=auto
ICAP_SURICATA_PORT=1345
ICAP_SURICATA_BYPASS=off
ICAP_SURICATA_MAX_CONN=32
ICAP_PERSISTENT_CONNECTIONS=off
ICAP_PREVIEW_ENABLE=on
ICAP_PREVIEW_SIZE=32768

ENABLE_CLAMAV_ICAP=0
CLAMAV_BYPASS=on
LOCAL_CLAMAV_SERVICE_NAME=pathb_avscan

ENABLE_INBOUND=0
INBOUND_BIND_IP=auto
INBOUND_HTTPS_PORT=443
INBOUND_DOMAIN=app-test.local
INBOUND_CERT=/etc/squid/inbound/app.fullchain.pem
INBOUND_KEY=/etc/squid/inbound/app.privkey.pem
INBOUND_ORIGIN_HOST=192.168.1.50
INBOUND_ORIGIN_PORT=443
INBOUND_ORIGIN_TLS=1
INBOUND_ORIGIN_VERIFY=0
